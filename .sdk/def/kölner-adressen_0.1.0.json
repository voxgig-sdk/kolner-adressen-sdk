{
  "openapi": "3.0.3",
  "info": {
    "title": "Kölner Adressen API",
    "description": "This API provides access to a dataset containing addresses within the city of Cologne. It includes geospatial information and various formats for data retrieval, enabling navigation and analysis of geographic data related to buildings and urban structures. The dataset contains approximately 163,000 address objects with geospatial coordinates and building information from the municipal area classification system (Kommunale Gebietsgliederung).",
    "version": "1.0.0",
    "contact": {
      "name": "Amt für Stadtentwicklung und Statistik - Raumbezogene Statistik Stadt Köln",
      "email": "statistik-rbs@stadt-koeln.de"
    },
    "license": {
      "name": "Datenlizenz Deutschland – Zero – Version 2.0",
      "url": "https://www.govdata.de/dl-de/zero-2-0"
    },
    "x-documentation": "https://offenedaten-koeln.de/dataset/adressen-k%C3%B6ln"
  },
  "servers": [
    {
      "url": "https://offenedaten-koeln.de",
      "description": "Offene Daten Köln Production Server"
    }
  ],
  "tags": [
    {
      "name": "Addresses",
      "description": "Operations related to Cologne address data"
    },
    {
      "name": "Geospatial",
      "description": "Geospatial data services including WFS and WMS"
    }
  ],
  "paths": {
    "/dataset/adressen-k%C3%B6ln": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "Get Cologne addresses dataset information",
        "description": "Retrieves metadata and information about the Cologne addresses dataset, including available formats and resources.",
        "operationId": "getAddressesDataset",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Format of the response",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "rdf",
                "dcat-ap"
              ],
              "default": "html"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved dataset information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetMetadata"
                }
              },
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/rdf+xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/3/action/datastore_search": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "Search addresses via DKAN API",
        "description": "Search and retrieve address data from the Cologne addresses dataset using the DKAN API endpoint. Returns approximately 163,000 address objects with geospatial coordinates.",
        "operationId": "searchAddresses",
        "parameters": [
          {
            "name": "resource_id",
            "in": "query",
            "description": "Resource ID for the addresses dataset",
            "required": true,
            "schema": {
              "type": "string",
              "example": "c2f2e522-00c5-4c0c-9168-d60e716020a3"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Search query string",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "JSON string of field filters",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Comma-separated list of fields to return",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved address data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "404": {
            "description": "Resource not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DatasetMetadata": {
        "type": "object",
        "description": "Metadata information about the Cologne addresses dataset",
        "properties": {
          "id": {
            "type": "string",
            "description": "Dataset identifier",
            "example": "c2f2e522-00c5-4c0c-9168-d60e716020a3"
          },
          "title": {
            "type": "string",
            "description": "Dataset title",
            "example": "Adressen Köln"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the dataset"
          },
          "publisher": {
            "type": "string",
            "description": "Publishing organization",
            "example": "Stadt Köln"
          },
          "modified": {
            "type": "string",
            "format": "date",
            "description": "Last modification date",
            "example": "2026-02-11"
          },
          "issued": {
            "type": "string",
            "format": "date",
            "description": "Publication date",
            "example": "2013-06-26"
          },
          "license": {
            "type": "string",
            "description": "License information",
            "example": "Datenlizenz Deutschland – Zero – Version 2.0"
          },
          "spatial": {
            "type": "string",
            "description": "Geographic coverage",
            "example": "http://www.geonames.org/2886242/"
          },
          "language": {
            "type": "string",
            "description": "Dataset language",
            "example": "de"
          },
          "resources": {
            "type": "array",
            "description": "Available data resources",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          }
        }
      },
      "Resource": {
        "type": "object",
        "description": "Information about a specific data resource",
        "properties": {
          "id": {
            "type": "string",
            "description": "Resource identifier"
          },
          "name": {
            "type": "string",
            "description": "Resource name"
          },
          "format": {
            "type": "string",
            "enum": [
              "WFS",
              "WMS",
              "KMZ",
              "JSON",
              "XLSX",
              "ZIP",
              "Shapefile"
            ],
            "description": "Data format"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Resource download or access URL"
          },
          "description": {
            "type": "string",
            "description": "Resource description"
          }
        }
      },
      "AddressSearchResponse": {
        "type": "object",
        "description": "Response from the address search API",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "result": {
            "type": "object",
            "properties": {
              "records": {
                "type": "array",
                "description": "Array of address records",
                "items": {
                  "$ref": "#/components/schemas/Address"
                }
              },
              "total": {
                "type": "integer",
                "description": "Total number of records matching the query",
                "example": 163000
              },
              "limit": {
                "type": "integer",
                "description": "Number of records returned per page"
              },
              "offset": {
                "type": "integer",
                "description": "Current offset for pagination"
              }
            }
          }
        }
      },
      "Address": {
        "type": "object",
        "description": "A single address record in Cologne",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique address identifier"
          },
          "strasse": {
            "type": "string",
            "description": "Street name",
            "example": "Kölner Straße"
          },
          "hausnummer": {
            "type": "string",
            "description": "House number",
            "example": "123"
          },
          "hausnummer_zusatz": {
            "type": "string",
            "description": "House number suffix",
            "example": "a"
          },
          "plz": {
            "type": "string",
            "description": "Postal code",
            "example": "50667"
          },
          "stadtbezirk": {
            "type": "string",
            "description": "City district (Stadtbezirk)"
          },
          "stadtteil": {
            "type": "string",
            "description": "District (Stadtteil)"
          },
          "stadtviertel": {
            "type": "string",
            "description": "Quarter (Stadtviertel)"
          },
          "statistisches_quartier": {
            "type": "string",
            "description": "Statistical quarter"
          },
          "block": {
            "type": "string",
            "description": "Block identifier"
          },
          "blockseite": {
            "type": "string",
            "description": "Block side"
          },
          "gebaeude_id_alkis": {
            "type": "string",
            "description": "Building ID from ALKIS (Amtliches Liegenschaftskataster-Informationssystem)"
          },
          "nutzung_gebaeude_funktion": {
            "type": "string",
            "description": "Building usage/function"
          },
          "rechtswert": {
            "type": "number",
            "format": "double",
            "description": "Easting coordinate (ETRS 1989 UTM Zone 32N)"
          },
          "hochwert": {
            "type": "number",
            "format": "double",
            "description": "Northing coordinate (ETRS 1989 UTM Zone 32N)"
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "Longitude (WGS84)",
            "minimum": -180,
            "maximum": 180
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "Latitude (WGS84)",
            "minimum": -90,
            "maximum": 90
          }
        }
      }
    }
  }
}
